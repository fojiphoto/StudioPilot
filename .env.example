# GameOS — required credentials. Copy to .env and fill in real values. NEVER commit .env.

# --- Core ---
GAMEOS_DB_URL=sqlite:///data/gameos.db        # or postgresql+psycopg://user:pass@host/db
GAMEOS_MODE=interval                          # continuous | interval | oneshot
GAMEOS_INTERVAL_MINUTES=10

# --- AppLovin MAX ---
APPLOVIN_REPORT_KEY=

# --- AdMob ---
ADMOB_CLIENT_ID=
ADMOB_CLIENT_SECRET=
ADMOB_REFRESH_TOKEN=
ADMOB_PUBLISHER_ID=

# --- Google Ads ---
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# --- Meta (Facebook) ---
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=            # long-lived (60d); exchange short token via fb_exchange_token
META_AD_ACCOUNT_IDS=          # comma-separated, e.g. act_123,act_456

# --- Mintegral ---
MINTEGRAL_ACCESS_KEY=         # "Access Key" in dashboard
MINTEGRAL_API_KEY=            # "API" key in dashboard (used for md5 token)

# --- Firebase / BigQuery ---
GOOGLE_APPLICATION_CREDENTIALS=               # path to service-account json (keep outside repo or in gitignored credentials/)
FIREBASE_BQ_PROJECT=
FIREBASE_BQ_DATASET=

# --- GameAnalytics ---
GAMEANALYTICS_API_KEY=
GAMEANALYTICS_SECRET=

# --- WhatsApp alerts (Cloud API; Telegram is banned in PK) ---
WHATSAPP_TOKEN=               # Meta app -> WhatsApp -> API Setup
WHATSAPP_PHONE_NUMBER_ID=     # sender "Phone number ID" (Meta test number)
WHATSAPP_TO=                  # recipient(s), comma-separated, e.g. 92300xxxxxxx
