# Automatic HTTPS (Let's Encrypt) for the portal + public collector endpoint.
{$DOMAIN} {
	# Public event ingest for the GameOS SDK (auth is per-game ingest key, not here).
	handle /collect* {
		reverse_proxy collector:8090
	}
	handle /health {
		reverse_proxy collector:8090
	}

	# Everything else = the portal, behind HTTP basic auth (single user).
	handle {
		basic_auth {
			{$DASHBOARD_USER} {$DASHBOARD_PASS_HASH}
		}
		reverse_proxy dashboard:8080
	}
}
